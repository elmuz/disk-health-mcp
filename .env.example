# Disk Health MCP - Environment Variables
# Copy to .env and fill in values

# SSH connection to target host
SSH_HOST=your-server.example.com
SSH_PORT=22
SSH_USERNAME=your-user
SSH_KEY_PATH=~/.ssh/id_ed25519

# InfluxDB (optional - for historical disk metrics)
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8186
INFLUXDB_DATABASE=telegraf
INFLUXDB_TOKEN=your-token

# Prometheus (optional - for node_exporter disk metrics)
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
PROMETHEUS_TOKEN=your-token

# Logging
MCP_LOG_LEVEL=INFO
